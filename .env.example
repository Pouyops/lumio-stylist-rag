# ---------------------------------------------------------------------------
# LUMIO Stylist RAG service — environment template.
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real secrets.
# ---------------------------------------------------------------------------

# --- LLM / embeddings (OpenAI-compatible) ---
# Default: OpenAI hosted API. For local Ollama use:
#   LLM_BASE_URL=http://localhost:11434/v1  LLM_API_KEY=ollama  LLM_MODEL=qwen2.5:7b
#   EMBED_BASE_URL=http://localhost:11434/v1 EMBED_API_KEY=ollama EMBED_MODEL=bge-m3 EMBED_DIM=1024
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# --- Vector store ---
# Leave QDRANT_URL empty to use an embedded on-disk store at QDRANT_LOCAL_PATH
# (no Docker needed). Set it (e.g. http://localhost:6333) to use a Qdrant server.
QDRANT_URL=
QDRANT_LOCAL_PATH=./qdrant_data
QDRANT_COLLECTION=lumio_products

# --- Connection to the LUMIO website ---
LUMIO_BASE_URL=http://localhost:3000
STYLIST_SYNC_SECRET=change-me-32-hex   # must equal web/.env value
STYLIST_API_KEY=change-me-32-hex       # must equal web/.env value
SYNC_INTERVAL_MINUTES=10

# --- Catalog source ---
# fixture = read scripts/dev_catalog_fixture.json (standalone dev)
# http    = pull from ${LUMIO_BASE_URL}/api/stylist/catalog (needs the §3a route)
CATALOG_SOURCE=fixture

PORT=8010
